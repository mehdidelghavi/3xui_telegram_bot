<% layout('layouts/main') -%>
<div class="max-w-2xl mx-auto bg-slate-900 p-6 rounded-xl border border-slate-800">

    <h2 class="text-xl font-bold mb-6">ویرایش کاربر</h2>
    <% if (success && success.length > 0) { %>
        <div class="bg-green-600 text-white px-4 py-2 rounded mb-4">
            <%= success[0] %>
        </div>
    <% } %>
    
    <% if (failed && failed.length > 0) { %>
        <div class="bg-red-600 text-white px-4 py-2 rounded mb-4">
            <%= failed[0] %>
        </div>
    <% } %>
    <form action="/users/edit/<%= user.id %>" method="POST" class="space-y-5">

        <!-- Fullname -->
        <div>
            <label class="block mb-1 text-sm text-gray-300">نام</label>
            <input type="text" name="fullname"
                   class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:outline-none focus:border-green-500 text-white" value="<%= user.fullname %>" disabled>
        </div>
        <% if (errors?.fullname) { %>
            <p class="text-red-400 text-sm mt-1">
                <%= errors.fullname.msg %>
            </p>
        <% } %>

        <!-- Username -->
        <div>
            <label class="block mb-1 text-sm text-gray-300">نام کاربری</label>
            <input type="text" name="username"
                   class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:outline-none focus:border-green-500 text-white" value="<%= user.username %>" disabled>
        </div>

        <!-- Chat_id -->
        <div>
            <label class="block mb-1 text-sm text-gray-300">آیدی عددی</label>
            <input type="text" name="chat_id"
                   class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:outline-none focus:border-green-500 text-white" value="<%= user.chat_id %>" disabled>
        </div>

        <!-- Chat_id -->
        <div>
            <label class="block mb-1 text-sm text-gray-300">نقش</label>
            <select name="role" class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:outline-none focus:border-green-500 text-white">
                <option value="ADMIN" <% if(user.role == "ADMIN"){ %> selected <% }%>>مدیر</option>
                <option value="USER" <% if(user.role == "USER"){ %> selected <% }%>>کاربر عادی</option>
                <option value="SELLER" <% if(user.role == "SELLER"){ %> selected <% }%>>فروشنده</option>
            </select>
        </div>
        <!-- Buttons -->
        <div class="flex justify-end gap-3 pt-4">

            <a href="/users"
               class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg">
                لغو
            </a>

            <button type="submit"
                    class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg">
                ذخیره
            </button>

        </div>

    </form>
</div>
