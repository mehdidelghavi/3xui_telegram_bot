<% layout('layouts/main') -%>

<%- block("styles").append(`<link rel="stylesheet" href="/src/tom-select.css"><style>
    /* container */
    .ts-control {
        background: #0f172a !important; /* slate-900 */
        border: 1px solid #334155 !important; /* slate-700 */
        color: white !important;
        border-radius: 10px;
        padding: 10px;
    }

    .ts-dropdown, .ts-control, .ts-control input::placeholder{
        color:#FFF;
        padding-right: 10px;
    }
    
    /* selected items */
    .ts-control .item {
        background: #22c55e !important; /* green-500 */
        color: white !important;
        border-radius: 6px;
        padding: 2px 6px;
    }
    
    /* dropdown */
    .ts-dropdown {
        background: #0f172a !important;
        border: 1px solid #334155 !important;
        color: white !important;
    }
    
    /* hover item */
    .ts-dropdown .active {
        background: #1e293b !important;
    }
    </style>`) %>

<div class="max-w-2xl mx-auto bg-slate-900 p-6 rounded-xl border border-slate-800">

    <h2 class="text-xl font-bold mb-6">ویرایش سرویس</h2>
    <% if (success && success.length > 0) { %>
        <div class="bg-green-600 text-white px-4 py-2 rounded mb-4">
            <%= success[0] %>
        </div>
    <% } %>
    
    <% if (failed && failed.length > 0) { %>
        <div class="bg-red-600 text-white px-4 py-2 rounded mb-4">
            <%= failed[0] %>
        </div>
    <% } %>
    <form action="/services/edit/<%= service.id %>" method="POST" class="space-y-5">

        <!-- Title -->
        <div>
            <label class="block mb-1 text-sm text-gray-300">نام سرویس</label>
            <input type="text" name="title"
                   class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:outline-none focus:border-green-500 text-white" value="<%= old?.title || service?.title %>">
        </div>
        <% if (errors?.title) { %>
            <p class="text-red-400 text-sm mt-1">
                <%= errors.title.msg %>
            </p>
        <% } %>
        <div>
            <label class="block mb-1 text-sm text-gray-300">انتخاب سرور</label>
            <select class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:outline-none focus:border-green-500 text-white" name="server_id">
                <% for(const serverItems of servers) { %>
                    <option value="<%= serverItems.id %>" <% if (serverItems.id == service.server.id){ %> selected <% } %>><%= serverItems.settings.name %></option>
                <% } %>
            </select>
        </div>
        <% if (errors?.server_id) { %>
            <p class="text-red-400 text-sm mt-1">
                <%= errors.server_id.msg %>
            </p>
        <% } %>
        <div>
            <label class="block mb-1 text-sm text-gray-300">انتخاب اینباند ها</label>
            <select class="" name="inboundIDS" id="inbounds" multiple>
                <% for(const inboundItems of inbounds) { %>
                    <option value="<%= inboundItems.id %>" <% if (inboundIDS.includes(Number(inboundItems.id))){ %> selected <% } %>><%= inboundItems.remark %> | <%= inboundItems.port %> </option>
                <% } %>
            </select>
        </div>
        <!-- Buttons -->
        <div class="flex justify-end gap-3 pt-4">

            <a href="/services"
               class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg">
                لغو
            </a>

            <button type="submit"
                    class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg">
                ذخیره
            </button>

        </div>

    </form>
</div>

<%- block("scripts").append(`<script src="/src/tom-select.complete.min.js"></script><script>
    new TomSelect("#inbounds", {
        plugins: ['remove_button'],
        placeholder: "انتخاب اینباند ها"
    });
    </script>`) %>
