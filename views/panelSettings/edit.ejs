<% layout('layouts/main') -%>
<div class="max-w-2xl mx-auto bg-slate-900 p-6 rounded-xl border border-slate-800">

    <h2 class="text-xl font-bold mb-6">ویرایش تنظیمات</h2>
    <% if (success && success.length > 0) { %>
        <div class="bg-green-600 text-white px-4 py-2 rounded mb-4">
            <%= success[0] %>
        </div>
    <% } %>
    
    <% if (failed && failed.length > 0) { %>
        <div class="bg-red-600 text-white px-4 py-2 rounded mb-4">
            <%= failed[0] %>
        </div>
    <% } %>
    <form action="/settings/edit/<%= panelSettings.id %>" method="POST" class="space-y-5">

        <!-- Username -->
        <div>
            <label class="block mb-1 text-sm text-gray-300">نام کاربری</label>
            <input type="text" name="username"
                   class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:outline-none focus:border-green-500 text-white" value="<%= old?.username || panelSettings.username %>">
        </div>
        <% if (errors?.username) { %>
            <p class="text-red-400 text-sm mt-1">
                <%= errors.username.msg %>
            </p>
        <% } %>

        <div>
            <label class="block mb-1 text-sm text-gray-300">رمز عبور</label>
            <input type="password" name="password"
                   class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 focus:outline-none focus:border-green-500 text-white">
        </div>
        <% if (errors?.password) { %>
            <p class="text-red-400 text-sm mt-1">
                <%= errors.password.msg %>
            </p>
        <% } %>
        <!-- Buttons -->
        <div class="flex justify-end gap-3 pt-4">

            <a href="/settings"
               class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg">
                لغو
            </a>

            <button type="submit"
                    class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg">
                ذخیره
            </button>

        </div>

    </form>
</div>